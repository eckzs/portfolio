---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const certs = (await getCollection('certifications')).sort(
  (a, b) => Number(b.data.date) - Number(a.data.date),
);

const issuerColor: Record<string, string> = {
  AWS: '#ff9900',
  Cisco: '#00bceb',
  'Red Hat': '#ee0000',
};
---

<BaseLayout title="Certificaciones" description="Credenciales y certificaciones de Erick López.">
  <section class="container">
    <header class="head">
      <p class="eyebrow">Credenciales</p>
      <h1>Certificaciones</h1>
      <p class="intro">
        Validaciones de mi conocimiento en cloud, redes y sistemas Linux —
        emitidas por AWS, Cisco y Red Hat.
      </p>
    </header>

    <div class="grid">
      {certs.map((c, i) => (
        <a
          href={c.data.link}
          target="_blank"
          rel="noopener"
          class="cert reveal"
          style={`animation-delay:${i * 60}ms`}
        >
          <div class="badge">
            {c.data.image
              ? <img src={c.data.image} alt={c.data.title} loading="lazy" />
              : <div class="ph">★</div>}
          </div>
          <div class="info">
            <span
              class="issuer"
              style={`--c:${issuerColor[c.data.issuer] ?? 'var(--accent)'}`}
            >{c.data.issuer}</span>
            <h3>{c.data.title}</h3>
            <span class="year">{c.data.date}</span>
            <span class="view link-arrow">Ver credencial <span class="arr">↗</span></span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .head { max-width: 60ch; margin-bottom: 3rem; }
  .head h1 { font-size: clamp(2.4rem, 6vw, 3.4rem); margin: 0.6rem 0 1rem; }
  .intro { color: var(--text-muted); font-size: 1.05rem; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.3rem;
  }

  .cert {
    display: flex;
    gap: 1.1rem;
    align-items: center;
    padding: 1.2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    box-shadow: var(--shadow-sm);
    transition: all 0.3s var(--ease);
  }
  .cert:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }

  .badge {
    flex: 0 0 108px;
    width: 108px;
    height: 108px;
    display: grid;
    place-items: center;
  }
  .badge img { width: 100%; height: 100%; object-fit: contain; }
  .ph {
    width: 100%; height: 100%;
    display: grid; place-items: center;
    border-radius: 12px;
    background: var(--surface);
    color: var(--accent);
    font-size: 1.6rem;
  }

  .info { display: flex; flex-direction: column; min-width: 0; }
  .issuer {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .info h3 {
    font-size: 1.02rem;
    line-height: 1.25;
    font-weight: 500;
    color: var(--text);
  }
  .cert:hover .info h3 { color: var(--accent); }
  .year {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    margin: 0.35rem 0 0.6rem;
  }
  .view { color: var(--text-muted); }
  .cert:hover .view { color: var(--accent); }
</style>
