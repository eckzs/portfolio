---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TechIcon from '../components/TechIcon.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featured = projects.slice(0, 3);

const experiences = await getCollection('experience');
const certs = await getCollection('certifications');

const stack = ['Go', 'Python', 'AWS', 'GCP', 'Terraform', 'Docker', 'Linux', 'RAG / AI'];
---

<BaseLayout>
  <!-- Hero -->
  <section class="container hero">
    {site.available && (
      <p class="status reveal">
        <span class="dot"></span> Disponible para nuevas oportunidades
      </p>
    )}

    <h1 class="reveal" style="animation-delay:60ms">
      {site.role.split(' & ')[0]} <span class="amp">&amp;</span><br />
      <em>{site.role.split(' & ')[1]}</em>
    </h1>

    <p class="lead reveal" style="animation-delay:140ms">{site.bio}</p>

    <div class="cta reveal" style="animation-delay:220ms">
      <a href="/projects" class="btn primary">Ver proyectos <span class="arr">→</span></a>
      <a href={`mailto:${site.email}`} class="btn ghost">Contacto</a>
      <div class="socials">
        <a href={site.socials.github} target="_blank" rel="noopener">GitHub</a>
        <span class="sep">·</span>
        <a href={site.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>

    <ul class="stack reveal" style="animation-delay:300ms">
      {stack.map((s) => <li><TechIcon name={s} /></li>)}
    </ul>
  </section>

  <!-- Quick stats -->
  <section class="container stats">
    <a href="/experience" class="stat">
      <span class="num">{experiences.length}</span>
      <span class="lbl">Experiencias</span>
    </a>
    <a href="/projects" class="stat">
      <span class="num">{projects.length}</span>
      <span class="lbl">Proyectos</span>
    </a>
    <a href="/certifications" class="stat">
      <span class="num">{certs.length}</span>
      <span class="lbl">Certificaciones</span>
    </a>
  </section>

  <!-- Featured work -->
  <section class="container work">
    <div class="section-head">
      <h2>Trabajo seleccionado</h2>
      <span class="count">/ {String(featured.length).padStart(2, '0')}</span>
    </div>

    <div class="grid">
      {featured.map((p, i) => (
        <ProjectCard
          slug={p.slug}
          title={p.data.title}
          description={p.data.description}
          date={p.data.date}
          tags={p.data.tags}
          image={p.data.image}
          github={p.data.github}
          demo={p.data.demo}
          index={i}
        />
      ))}
    </div>

    <a href="/projects" class="link-arrow more">Ver todos los proyectos <span class="arr">→</span></a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4rem;
    padding-bottom: 4.5rem;
    max-width: 880px;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    margin-bottom: 1.8rem;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4caf72;
    box-shadow: 0 0 0 0 rgba(76, 175, 114, 0.5);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(76, 175, 114, 0.45); }
    70% { box-shadow: 0 0 0 7px rgba(76, 175, 114, 0); }
    100% { box-shadow: 0 0 0 0 rgba(76, 175, 114, 0); }
  }

  h1 {
    font-size: clamp(2.6rem, 8vw, 5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    margin-bottom: 1.6rem;
  }
  h1 em { font-style: italic; color: var(--accent); }
  h1 .amp { color: var(--text-faint); font-style: italic; }

  .lead {
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 60ch;
  }

  .cta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.94rem;
    font-weight: 500;
    padding: 0.7rem 1.3rem;
    border-radius: 100px;
    border: 1px solid transparent;
    transition: all 0.25s var(--ease);
  }
  .btn .arr { transition: transform 0.25s var(--ease); }
  .btn:hover .arr { transform: translateX(3px); }
  .btn.primary { background: var(--accent); color: #fff; }
  .btn.primary:hover { background: var(--accent-hover); color: #fff; transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .btn.ghost { color: var(--text); border-color: var(--border-strong); }
  .btn.ghost:hover { background: var(--surface); }

  .socials {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.3rem;
    font-size: 0.9rem;
  }
  .socials a { color: var(--text-muted); font-weight: 500; }
  .socials a:hover { color: var(--accent); }
  .socials .sep { color: var(--text-faint); }

  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 2.6rem 0 0;
  }

  /* Stats */
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 4rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.5rem 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated);
    transition: all 0.3s var(--ease);
  }
  .stat:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .stat .num {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    line-height: 1;
    color: var(--text);
  }
  .stat .lbl {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Work */
  .work { padding-bottom: 2rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.4rem;
  }
  .more {
    display: inline-flex;
    margin-top: 2.2rem;
    color: var(--accent);
  }

  @media (max-width: 560px) {
    .stats { grid-template-columns: 1fr; }
    .stat { flex-direction: row; align-items: baseline; gap: 0.7rem; justify-content: space-between; }
  }
</style>
