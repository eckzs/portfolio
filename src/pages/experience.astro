---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TechIcon from '../components/TechIcon.astro';

const raw = await getCollection('experience');
// keep insertion order (position-1 = most recent)
const experiences = await Promise.all(
  raw.map(async (e) => ({ data: e.data, Content: (await e.render()).Content })),
);

const fmtDate = (d: string) =>
  d.replace(/-to-/, ' — ').replace(/-/g, ' ');
---

<BaseLayout title="Experiencia" description="Trayectoria profesional de Erick López.">
  <section class="container">
    <header class="head">
      <p class="eyebrow">Trayectoria</p>
      <h1>Experiencia</h1>
      <p class="intro">
        Roles de ingeniería donde he construido backends, pipelines de datos
        e infraestructura en la nube para empresas y negocios locales.
      </p>
    </header>

    <ol class="timeline">
      {experiences.map((exp, i) => (
        <li class="item reveal" style={`animation-delay:${i * 80}ms`}>
          <div class="node"><span class="ring"></span></div>
          <div class="content">
            <p class="when">{fmtDate(exp.data.date)}</p>
            <h2 class="role">{exp.data.title}</h2>
            <p class="company">{exp.data.company}</p>
            <div class="desc prose">
              <exp.Content />
            </div>
            {exp.data.tags && (
              <div class="tags">
                {exp.data.tags.map((t) => <TechIcon name={t} />)}
              </div>
            )}
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .head { max-width: 60ch; margin-bottom: 3.5rem; }
  .head h1 { font-size: clamp(2.4rem, 6vw, 3.4rem); margin: 0.6rem 0 1rem; }
  .intro { color: var(--text-muted); font-size: 1.05rem; }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    max-width: 760px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 1.5px;
    background: linear-gradient(var(--border-strong), var(--border) 80%, transparent);
  }

  .item {
    position: relative;
    padding: 0 0 3rem 2.6rem;
  }
  .item:last-child { padding-bottom: 0.5rem; }

  .node {
    position: absolute;
    left: 0;
    top: 5px;
    width: 16px;
    height: 16px;
    display: grid;
    place-items: center;
  }
  .ring {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  .item:first-child .ring { background: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }

  .when {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    text-transform: capitalize;
    color: var(--text-faint);
    margin-bottom: 0.4rem;
  }
  .role { font-size: 1.5rem; }
  .company {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0.15rem 0 0.9rem;
  }
  .desc { font-size: 0.95rem; color: var(--text-muted); }
  .desc :global(p) { margin: 0; }
  .desc :global(p + p) { margin-top: 0.6rem; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.1rem;
  }
</style>
