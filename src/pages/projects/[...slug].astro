---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechIcon from '../../components/TechIcon.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, description, date, tags = [], image, github, demo } = project.data;
const fmt = date.toLocaleDateString('es', { year: 'numeric', month: 'long' });
---

<BaseLayout title={title} description={description}>
  <article class="container article">
    <a href="/projects" class="back link-arrow"><span class="arr back-arr">←</span> Proyectos</a>

    <header class="head">
      <p class="when">{fmt}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>

      <div class="actions">
        {github && <a href={github} target="_blank" rel="noopener" class="btn">↗ Repositorio</a>}
        {demo && <a href={demo} target="_blank" rel="noopener" class="btn primary">↗ Demo en vivo</a>}
      </div>

      <div class="tags">
        {tags.map((t) => <TechIcon name={t} />)}
      </div>
    </header>

    {image && (
      <div class="hero-img">
        <img src={image} alt={title} />
      </div>
    )}

    <div class="prose body">
      <Content />
    </div>

    <footer class="foot">
      <a href="/projects" class="link-arrow"><span class="arr back-arr">←</span> Volver a proyectos</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .article { max-width: 760px; }

  .back {
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }
  .back:hover { color: var(--accent); }
  .back-arr { display: inline-block; transition: transform 0.25s var(--ease); }
  .back:hover .back-arr { transform: translateX(-3px); }

  .when {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--text-faint);
    text-transform: capitalize;
    margin-bottom: 0.7rem;
  }
  .head h1 {
    font-size: clamp(2.2rem, 6vw, 3.4rem);
    margin-bottom: 1rem;
  }
  .lead {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .actions { display: flex; gap: 0.8rem; flex-wrap: wrap; margin: 1.8rem 0 1.2rem; }
  .btn {
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.6rem 1.1rem;
    border-radius: 100px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    transition: all 0.25s var(--ease);
  }
  .btn:hover { background: var(--surface); transform: translateY(-2px); }
  .btn.primary { background: var(--accent); color: #fff; border-color: transparent; }
  .btn.primary:hover { background: var(--accent-hover); color: #fff; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  .hero-img {
    margin: 2.8rem 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
  }
  .hero-img img { width: 100%; max-height: 460px; object-fit: cover; }

  .body { margin-top: 2.5rem; }

  .foot {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .foot a { color: var(--accent); }
</style>
