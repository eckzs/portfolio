---
import { getTech } from '../data/tech';

interface Props {
  name: string;
}
const { name } = Astro.props;
const def = getTech(name);
const style = def
  ? `--brand:${def.hex};${def.hexDark ? `--brand-dark:${def.hexDark};` : ''}`
  : undefined;
---

{def ? (
  <span class="tech" style={style}>
    <svg class="ico" viewBox="0 0 24 24" width="13" height="13" aria-hidden="true">
      <path d={def.path} fill="currentColor" />
    </svg>
    <span class="lbl">{def.label}</span>
  </span>
) : (
  <span class="tech plain">{name}</span>
)}

<style>
  .tech {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.01em;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.24rem 0.58rem;
    border-radius: 100px;
    white-space: nowrap;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .tech .ico {
    color: var(--text-faint);
    flex: 0 0 auto;
    transition: color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .tech:hover {
    color: var(--text);
    border-color: var(--border-strong);
    background: var(--surface-hover);
  }
  .tech:hover .ico {
    color: var(--brand);
    transform: scale(1.1);
  }
  :global([data-theme='dark']) .tech:hover .ico {
    color: var(--brand-dark, var(--brand));
  }
  .plain { padding-left: 0.62rem; }
</style>
