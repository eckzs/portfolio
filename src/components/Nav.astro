---
import ThemeToggle from './ThemeToggle.astro';
import { site, nav } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={site.name}>
      <span class="mono">~/</span>{site.name.toLowerCase().replace(' ', '-')}
    </a>

    <nav class="links" aria-label="Principal">
      {nav.map((item) => (
        <a href={item.href} class:list={['link', { active: isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="actions">
      <ThemeToggle />
      <button class="menu-btn" id="menu-btn" aria-label="Menú">
        <span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="mobile" id="mobile-menu" aria-label="Móvil">
    {nav.map((item) => (
      <a href={item.href} class:list={['link', { active: isActive(item.href) }]}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script is:inline>
  (() => {
    const bind = () => {
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (!btn || !menu || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        btn.classList.toggle('open', open);
      });
    };
    bind();
    document.addEventListener('astro:after-swap', bind);
  })();
</script>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .brand:hover { color: var(--accent); }
  .brand .mono { color: var(--accent); }

  .links {
    display: flex;
    gap: 0.35rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 0.45rem 0.85rem;
    border-radius: 9px;
    transition: all 0.2s var(--ease);
  }
  .link:hover { color: var(--text); background: var(--surface); }
  .link.active { color: var(--accent); }

  .actions { display: flex; align-items: center; gap: 0.6rem; }

  .menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    padding: 0 9px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    cursor: pointer;
  }
  .menu-btn span {
    height: 1.6px;
    width: 100%;
    background: var(--text-muted);
    border-radius: 2px;
    transition: transform 0.25s var(--ease), opacity 0.2s var(--ease);
  }
  .menu-btn.open span:first-child { transform: translateY(3.3px) rotate(45deg); }
  .menu-btn.open span:last-child { transform: translateY(-3.3px) rotate(-45deg); }

  .mobile {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    gap: 0.15rem;
    border-top: 1px solid var(--border);
  }
  .mobile.open { display: flex; }
  .mobile .link { padding: 0.7rem 0.5rem; font-size: 1rem; }

  @media (max-width: 760px) {
    .links { display: none; }
    .menu-btn { display: flex; }
  }
</style>
