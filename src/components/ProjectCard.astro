---
import TechIcon from './TechIcon.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  image?: string;
  github?: string;
  demo?: string;
  index?: number;
}
const { slug, title, description, date, tags = [], image, github, demo, index = 0 } = Astro.props;
const year = date.getFullYear();
---

<article class="card reveal" style={`animation-delay:${index * 70}ms`}>
  <a href={`/projects/${slug}`} class="cover" aria-label={title}>
    {image
      ? <img src={image} alt={title} loading="lazy" />
      : <div class="cover-fallback"><span>{title.charAt(0)}</span></div>}
  </a>

  <div class="body">
    <div class="meta">
      <span class="year">{year}</span>
      <div class="ext">
        {github && <a href={github} target="_blank" rel="noopener" title="GitHub">↗ code</a>}
        {demo && <a href={demo} target="_blank" rel="noopener" title="Demo">↗ demo</a>}
      </div>
    </div>

    <h3><a href={`/projects/${slug}`}>{title}</a></h3>
    <p class="desc">{description}</p>

    <div class="tags">
      {tags.slice(0, 5).map((t) => <TechIcon name={t} />)}
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease), border-color 0.35s var(--ease);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-strong);
  }

  .cover {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .card:hover .cover img { transform: scale(1.04); }
  .cover-fallback {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--surface), var(--bg-elevated));
  }
  .cover-fallback span {
    font-family: var(--font-serif);
    font-size: 2.6rem;
    color: var(--accent);
    opacity: 0.55;
  }

  .body { padding: 1.25rem 1.35rem 1.4rem; display: flex; flex-direction: column; flex: 1; }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.6rem;
  }
  .year {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .ext { display: flex; gap: 0.8rem; }
  .ext a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .ext a:hover { color: var(--accent); }

  h3 { font-size: 1.35rem; margin-bottom: 0.45rem; }
  h3 a { color: var(--text); }
  h3 a:hover { color: var(--accent); }

  .desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 1.1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }
</style>
