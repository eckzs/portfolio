---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container foot-inner">
    <div class="foot-left">
      <p class="name">{site.fullName}</p>
      <p class="muted">{site.role} · {site.location}</p>
    </div>
    <div class="foot-links">
      <a href={site.socials.github} target="_blank" rel="noopener">GitHub</a>
      <a href={site.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={`mailto:${site.email}`}>Email</a>
    </div>
  </div>
  <div class="container foot-bottom">
    <span class="mono">© {year} · built with Astro</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 3rem 0 2.5rem;
    margin-top: 2rem;
  }
  .foot-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .name { font-family: var(--font-serif); font-size: 1.15rem; }
  .muted { color: var(--text-muted); font-size: 0.9rem; margin-top: 0.2rem; }
  .foot-links { display: flex; gap: 1.5rem; }
  .foot-links a {
    color: var(--text-muted);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .foot-links a:hover { color: var(--accent); }
  .foot-bottom { margin-top: 2.5rem; }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
</style>
